{
  "name": "roger-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.21.0",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/assets/styles/main.css"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "run-s build:lib build:types build:styles",
    "build:lib": "vite build",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "build:styles": "mkdir -p dist/assets/styles && cp src/assets/styles/main.css dist/assets/styles/main.css",
    "ci": "run-s type-check lint:check test:unit:ci build build-storybook",
    "test:unit": "vitest",
    "test:unit:ci": "vitest --run",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:oxlint lint:eslint",
    "lint:check": "run-s lint:oxlint:check lint:eslint:check",
    "lint:oxlint": "oxlint . --fix",
    "lint:oxlint:check": "oxlint .",
    "lint:eslint": "eslint . --fix --cache",
    "lint:eslint:check": "eslint . --cache",
    "format": "prettier --write --experimental-cli src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/vue3-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.10",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.51.0",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.51.0",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
